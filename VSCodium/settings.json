{
    "editor.formatOnSave": true,
    "workbench.iconTheme": "catppuccin-mocha",
    "editor.minimap.renderCharacters": false,
    "workbench.editor.wrapTabs": true,
    "editor.smoothScrolling": true,
    "workbench.list.smoothScrolling": true,
    "terminal.integrated.smoothScrolling": true,
    "frosted-glass-theme.fakeMica.enabled": true,
    "frosted-glass-theme.fakeMica.titlebarFix": 0.4,
    "workbench.secondarySideBar.showLabels": false,
    "apc.imports": [
        "file:///Users/fimgrund/.vscode-oss/extensions/brandonkirbyson.vscode-animations-2.0.1-universal/dist/updateHandler.js"
    ],
    "animations.Enabled": true,
    "redhat.telemetry.enabled": false,
    "files.associations": {
        ".aerospace.toml": "ini",
        "*.heex": "phoenix-heex",
        "*.toml": "toml"
    },
    "workbench.editorAssociations": {
        "*.docx": "default"
    },
    "workbench.activityBar.location": "top",
    "terminal.integrated.stickyScroll.enabled": false,
    "editor.stickyScroll.enabled": false,
    "[dockercompose]": {
        "editor.insertSpaces": true,
        "editor.tabSize": 2,
        "editor.autoIndent": "advanced",
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "[github-actions-workflow]": {
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "explorer.confirmDragAndDrop": false,
    "lexical.notifyOnServerAutoUpdate": false,
    "editor.fontLigatures": true,
    "editor.fontFamily": "'Jetbrains Mono'",
    "[phoenix-heex]": {
        "editor.defaultFormatter": "elixir-lsp.elixir-ls"
    },
    "editor.autoIndentOnPaste": true,
    "emmet.includeLanguages": {
        "phoenix-heex": "html"
    },
    "tailwindCSS.emmetCompletions": true,
    "tailwindCSS.includeLanguages": {
        "heex": "html",
        "eelixir": "html"
    },
    "editor.minimap.enabled": false,
    "window.newWindowProfile": "Default",
    "search.actionsPosition": "auto",
    "files.exclude": {
        "**/.git": false,
        "**/.svn": false
    },
    "direnv.path.executable": "/opt/homebrew/bin/direnv",
    "explorer.autoReveal": false,
    "notes.notesLocation": "/Users/fimgrund/code/work/nedeco/elixir/vanitas_notes",
    "window.menuBarVisibility": "toggle",
    "workbench.colorTheme": "Material Code",
    "material-code.colors": {
        "primary": "{{colors.primary.default.hex}}",
        "foreground": "{{colors.on_surface.default.hex}}",
        "mutedForeground": "{{colors.on_surface_variant.default.hex}}",
        "background": "{{colors.surface.default.hex}}",
        "card": "{{colors.surface_container.default.hex}}",
        "popover": "{{colors.surface_container_high.default.hex}}",
        "hover": "{{colors.surface_container_highest.default.hex}}",
        "border": "{{colors.outline_variant.default.hex}}",
        "primaryForeground": "{{colors.on_primary.default.hex}}",
        "secondary": "{{colors.secondary_container.default.hex}}",
        "secondaryForeground": "{{colors.on_secondary_container.default.hex}}"
    }
}